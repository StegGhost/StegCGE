{
  "$schema": "https://stegverse.org/schemas/architecture_manifest.schema.json",
  "schema_version": "1.0.0",
  "repo_id": "StegCGE",
  "repo_type": "engine",
  "description": "StegCGE -- the layer that makes AI-generated code trustworthy. Code Generation and Evaluation engine with governance constraints.",
  "inherits_from": null,
  "enforcement": "strict",
  
  "expected_structure": {
    "docs/architecture/ARCHITECTURE.md": {
      "required": true,
      "purpose": "Canonical architecture documentation"
    },
    "docs/architecture/decisions/": {
      "required": true,
      "purpose": "Architecture Decision Records"
    },
    "cge/": {
      "required": true,
      "purpose": "Main CGE package",
      "subdirs": {
        "__init__.py": { "required": true },
        "generator.py": { "required": false, "purpose": "Code generation" },
        "evaluator.py": { "required": false, "purpose": "Code evaluation" },
        "governance.py": { "required": false, "purpose": "Governance constraints" },
        "trust.py": { "required": false, "purpose": "Trust scoring" }
      }
    },
    "demo/": {
      "required": true,
      "purpose": "Runnable demonstrations"
    },
    "tests/": {
      "required": true,
      "purpose": "Test suite"
    },
    "scripts/": {
      "required": false,
      "purpose": "Utility scripts"
    },
    "requirements.txt": {
      "required": true,
      "purpose": "Runtime dependencies"
    },
    "pyproject.toml": {
      "required": true,
      "purpose": "Modern Python packaging"
    },
    "README.md": {
      "required": true,
      "purpose": "Project overview"
    },
    "LICENSE": {
      "required": true,
      "purpose": "Software license"
    },
    ".github/workflows/": {
      "required": true,
      "purpose": "CI/CD workflows"
    }
  },

  "file_rules": {
    "naming_conventions": {
      "python_modules": "snake_case",
      "classes": "PascalCase",
      "functions": "snake_case",
      "test_files": "test_*.py"
    },
    "forbidden_patterns": [
      ".*secret.*",
      ".*password.*",
      "\\.env$",
      "\\.pyc$",
      "__pycache__"
    ]
  },

  "migration_rules": {
    "review_needed_path": "review_needed/",
    "legacy_path": "legacy/",
    "wiring_path": "wiring/",
    "auto_migrate": false,
    "require_approval": true,
    "syntax_issue_patterns": [
      ".*\\s+.*",
      ".*[^a-zA-Z0-9_\\-\\./].*"
    ]
  },

  "validation_hooks": {
    "pre_commit": true,
    "ci_pull_request": true,
    "ci_push_main": true
  },

  "integration_points": {
    "sdk": "github.com/StegVerse-org/StegVerse-SDK",
    "entity_sandbox_runner": "github.com/StegGhost/entity-sandbox-runner",
    "automated_buildout": "github.com/StegGhost/automated_buildout"
  }
}
